rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidBook(data) {
      return data.keys().hasAll(['title', 'author', 'rating', 'userId', 'saveDate']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.userId == request.auth.uid &&
             data.saveDate is string;
    }

    match /books/{bookId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidBook(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidBook(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
